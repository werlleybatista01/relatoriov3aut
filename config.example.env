# Modelo seguro. O instalador de produção reaproveita automaticamente o
# config.env existente e não revela a senha.
BACKUP_DIR=C:\CAMINHO\PARA\BACKUPS_FECHADOS
BACKUP_PATTERNS=Backup * - Banco de Dados 11.0.mdb;*.accdb
ACCESS_PASSWORD=SUA_SENHA_AQUI

# Repositório/pasta modular que contém index.html, src/, data/ e downloads/.
REPO_DIR=C:\CAMINHO\PARA\HOMOLOGACAO
DATA_FILE=data/dashboard-data.js
DOWNLOAD_FILE=downloads/relatorio_almoxarifado_2026.xlsx

# Modo seguro para testes manuais. O instalador troca estes dois valores para
# false/true somente no computador de produção.
HOMOLOGATION_MODE=true
GIT_PUSH=false

OPERATING_YEAR=2026
SEASONAL_HISTORY_YEAR=2025
SACOLAS_POR_PACOTE=100

# Segurança dos dados.
# Para comparar nomes apenas localmente, use INCLUDE_PERSONAL_DATA=true
# mantendo GIT_PUSH=false.
INCLUDE_PERSONAL_DATA=false
ALLOW_PUBLIC_PERSONAL_DATA=false
DIRECT_WHATSAPP_ENABLED=false

TOOL_CLASSIFICATION_FILE=classificacao_ferramentas.json
TOOL_CLASSIFICATION_PENDING_FILE=produtos_pendentes_classificacao.csv

# Arquivos separados da produção para evitar conflito.
STATE_FILE=estado_atualizador_modular.json
LOCK_FILE=.atualizador_modular.lock

LOCK_STALE_MINUTES=120
BACKUP_STABILITY_SECONDS=2
BACKUP_STABILITY_ATTEMPTS=4
MAX_RECORD_DROP_PERCENT=15
ALLOW_RECORD_DROP=false
ALLOW_BACKUP_REGRESSION=false
